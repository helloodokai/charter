{
  "title": "Charter",
  "description": "A machine-readable specification hardened from fuzzy human intent",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Schema version, always \"1\""
    },
    "id": {
      "type": "string",
      "pattern": "^ch-\\d{4}-\\d{2}-\\d{2}-[a-f0-9]+$",
      "description": "Human-friendly charter ID"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the charter was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the charter was last updated"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Authors of the charter"
    },
    "source": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github_issue", "file", "stdin", "slack"],
          "description": "Source type"
        },
        "url": {
          "type": "string",
          "description": "URL if from a GitHub issue"
        },
        "raw": {
          "type": "string",
          "description": "Raw source text"
        }
      },
      "required": ["type"]
    },
    "goal": {
      "type": "string",
      "description": "One-sentence statement of intent"
    },
    "context": {
      "type": "string",
      "description": "Background an agent needs to understand the goal"
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit scope exclusions"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string" },
          "verification": {
            "type": "string",
            "enum": ["test", "manual", "metric"],
            "description": "How to verify this criterion"
          },
          "test_hint": { "type": "string" }
        },
        "required": ["id", "statement", "verification"]
      }
    },
    "edge_cases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scenarios the agent must handle"
    },
    "constraints": {
      "type": "object",
      "properties": {
        "performance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "security": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compatibility": {
          "type": "array",
          "items": { "type": "string" }
        },
        "style": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "blocking": { "type": "boolean" }
        },
        "required": ["id", "question", "blocking"]
      }
    },
    "blast_radius": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for affected files"
        },
        "services": {
          "type": "array",
          "items": { "type": "string" }
        },
        "data": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tables, queues, topics"
        }
      }
    },
    "verification_plan": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rollback_plan": {
      "type": "string",
      "description": "Required for high/critical risk charters"
    },
    "counter_spec": {
      "type": "object",
      "properties": {
        "misinterpretations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ways an agent could misinterpret the goal"
        },
        "ambiguities_flagged": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "risk_rationale": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "approved", "archived"]
    },
    "transcript": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["tool", "human"] },
          "at": { "type": "string", "format": "date-time" },
          "content": { "type": "string" }
        }
      },
      "description": "Audit trail of the Socratic dialogue"
    }
  },
  "required": ["schema_version", "id", "goal", "source", "status"]
}